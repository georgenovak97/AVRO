<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Диспетчер семейств"
        Height="860" Width="1240"
        MinHeight="600" MinWidth="920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="12"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Revit-like light palette -->
        <SolidColorBrush x:Key="BgWindow"      Color="#F0F0F0"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgSidebar"     Color="#E4E4E4"/>
        <SolidColorBrush x:Key="BgToolbar"     Color="#F5F5F5"/>
        <SolidColorBrush x:Key="BorderMain"    Color="#ABABAB"/>
        <SolidColorBrush x:Key="BorderLight"   Color="#D0D0D0"/>
        <SolidColorBrush x:Key="TextMain"      Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#5A5A5A"/>
        <SolidColorBrush x:Key="SelBg"         Color="#CCE8FF"/>
        <SolidColorBrush x:Key="SelBorder"     Color="#3399FF"/>
        <SolidColorBrush x:Key="BtnFace"       Color="#E1E1E1"/>
        <SolidColorBrush x:Key="BtnFaceHov"    Color="#CCE4F7"/>
        <SolidColorBrush x:Key="BtnBorder"     Color="#707070"/>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Padding" Value="2,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelBg}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SelBorder}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EDEDED"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RevitButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BtnFace}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnFaceHov}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B9D7F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RevitButtonPrimary" TargetType="Button" BasedOn="{StaticResource RevitButton}">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource RevitButton}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>

        <Style x:Key="ClearSearchButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                                <Setter Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgWindow}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ MAIN (Revit Open dialog layout) ═══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="354" MinWidth="280"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Places / library tree -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}"
                    BorderBrush="{StaticResource BorderMain}" BorderThickness="0,0,1,0">
                <TreeView x:Name="CategoryTree"
                          Margin="4,8,4,8"/>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderLight}"
                          HorizontalAlignment="Stretch"/>

            <!-- CENTER: folder bar + file list -->
            <Grid Grid.Column="2" Background="{StaticResource BgPanel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar row (Папка + path) -->
                <Border Grid.Row="0" Background="{StaticResource BgToolbar}"
                        BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1"
                        Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Папка:"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{StaticResource TextMain}"/>
                        <TextBlock x:Name="BreadcrumbText" Grid.Column="1"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextMain}"/>
                        <TextBlock x:Name="CountText" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource TextMuted}" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Search + разделитель на всю ширину панели -->
                <Grid Grid.Row="1">
                    <Border Height="1" VerticalAlignment="Bottom"
                            Background="{StaticResource BorderLight}"
                            HorizontalAlignment="Stretch"/>
                    <Border VerticalAlignment="Top"
                            Padding="8,6,8,6" HorizontalAlignment="Stretch"
                            BorderThickness="0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="SearchBox" Padding="6,4,34,4"
                                         VerticalContentAlignment="Center"/>
                                <TextBlock Text="Поиск семейств…"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center" Margin="8,0,34,0"
                                           Foreground="{StaticResource TextMuted}" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button x:Name="BtnClearSearch" Grid.Column="1"
                                    Content="&#x00D7;"
                                    Style="{StaticResource ClearSearchButton}"
                                    VerticalAlignment="Center"
                                    ToolTip="Очистить поиск"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Family grid with previews -->
                <ScrollViewer x:Name="FamilyScrollViewer" Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{StaticResource BgPanel}"
                              Margin="8,0,8,0">
                    <WrapPanel x:Name="FamilyPanel"
                               Orientation="Horizontal"
                               Margin="0"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Border Grid.Row="1" Background="{StaticResource BgToolbar}"
                BorderBrush="{StaticResource BorderMain}" BorderThickness="0,1,0,0"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Готово"
                           Foreground="{StaticResource TextMuted}" FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnSettings"
                            Content="Библиотека" Style="{StaticResource RevitButton}"
                            MinWidth="88" ToolTip="Выбрать папку библиотеки"/>
                    <Button x:Name="BtnReload"
                            Content="Обновить" Style="{StaticResource RevitButton}"
                            MinWidth="88" Margin="6,0,0,0"
                            ToolTip="Пересканировать библиотеку"/>
                    <Border Width="1" Margin="10,2,10,2"
                            Background="{StaticResource BorderMain}"
                            VerticalAlignment="Stretch"/>
                    <Button x:Name="BtnLoadSelected"
                            Content="Загрузить" Style="{StaticResource RevitButtonPrimary}"
                            MinWidth="96" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
