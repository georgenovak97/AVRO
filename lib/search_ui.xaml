<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="600" Height="292"
        MinWidth="480" MinHeight="292" MaxHeight="292"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <SolidColorBrush x:Key="BgWindow"    Color="#F0F0F0"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgInput"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderMain"  Color="#D4D4D4"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="TextMain"    Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#888888"/>
        <SolidColorBrush x:Key="SelBg"       Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TreeHoverBg" Color="#F5F5F5"/>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgPanel}"
            BorderBrush="{DynamicResource BorderMain}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,8,10,0">
                <TextBox x:Name="SearchBox"
                         FontSize="15"
                         MinHeight="30"
                         Background="{DynamicResource BgInput}"
                         Foreground="{DynamicResource TextMain}"
                         CaretBrush="{DynamicResource TextMain}"
                         BorderBrush="{DynamicResource BorderLight}"
                         BorderThickness="0,0,0,1"
                         Padding="2,4,24,6"/>
                <Button x:Name="ClearSearchButton"
                        Width="18"
                        Height="18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,2,4"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TextMuted}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Focusable="False"
                        Visibility="Collapsed"
                        Content="×"/>
            </Grid>

            <Grid x:Name="TopCommandsBar"
                  Grid.Row="1"
                  Margin="10,8,10,0"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="TopCmd0"
                        Grid.Column="0"
                        Margin="0,0,6,0"
                        Padding="10,6"
                        Background="{DynamicResource BgWindow}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        Focusable="False">
                    <TextBlock x:Name="TopCmd0Text"
                               Text=""
                               Foreground="{DynamicResource TextMain}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               ClipToBounds="True"/>
                </Button>

                <Button x:Name="TopCmd1"
                        Grid.Column="1"
                        Margin="0,0,6,0"
                        Padding="10,6"
                        Background="{DynamicResource BgWindow}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        Focusable="False">
                    <TextBlock x:Name="TopCmd1Text"
                               Text=""
                               Foreground="{DynamicResource TextMain}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               ClipToBounds="True"/>
                </Button>

                <Button x:Name="TopCmd2"
                        Grid.Column="2"
                        Margin="0,0,6,0"
                        Padding="10,6"
                        Background="{DynamicResource BgWindow}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        Focusable="False">
                    <TextBlock x:Name="TopCmd2Text"
                               Text=""
                               Foreground="{DynamicResource TextMain}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               ClipToBounds="True"/>
                </Button>

                <Button x:Name="TopCmd3"
                        Grid.Column="3"
                        Margin="0,0,6,0"
                        Padding="10,6"
                        Background="{DynamicResource BgWindow}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        Focusable="False">
                    <TextBlock x:Name="TopCmd3Text"
                               Text=""
                               Foreground="{DynamicResource TextMain}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               ClipToBounds="True"/>
                </Button>

                <Button x:Name="TopCmd4"
                        Grid.Column="4"
                        Margin="0,0,6,0"
                        Padding="10,6"
                        Background="{DynamicResource BgWindow}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        Focusable="False">
                    <TextBlock x:Name="TopCmd4Text"
                               Text=""
                               Foreground="{DynamicResource TextMain}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               ClipToBounds="True"/>
                </Button>

                <Button x:Name="TopCmd5"
                        Grid.Column="5"
                        Margin="0,0,0,0"
                        Padding="10,6"
                        Background="{DynamicResource BgWindow}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        Focusable="False">
                    <TextBlock x:Name="TopCmd5Text"
                               Text=""
                               Foreground="{DynamicResource TextMain}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               TextTrimming="None"
                               ClipToBounds="True"/>
                </Button>
            </Grid>

            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     Margin="4,6,4,0"
                     Background="{DynamicResource BgPanel}"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     Focusable="False"
                     IsTabStop="False"
                     KeyboardNavigation.TabNavigation="None"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="TopSeparator"
                                    Grid.Row="0"
                                    Height="1"
                                    Margin="8,8,14,8"
                                    Background="{DynamicResource BorderMain}"
                                    HorizontalAlignment="Stretch"
                                    Visibility="Collapsed"/>
                            <Border x:Name="ItemBody"
                                    Grid.Row="1"
                                    Margin="0,0,14,0"
                                    Padding="8,4"
                                    Background="Transparent">
                                <TextBlock FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding Name}" Foreground="{DynamicResource TextMain}"/>
                                    <Run Text="{Binding PathSuffix}" Foreground="{DynamicResource TextMuted}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                <Setter TargetName="TopSeparator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ItemBody" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="ItemBody" Property="Background" Value="{DynamicResource SelBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="ItemBody" Property="Background" Value="{DynamicResource TreeHoverBg}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
